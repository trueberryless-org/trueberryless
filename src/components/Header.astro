---
const links = [
  { label: "Posts", url: "/posts" },
  { label: "Books", url: "/books" },
  { label: "Events", url: "/events" },
];
---

<header class="glass-header">
  <div class="header-inner">
    <a href="/" class="logo">Felix Schneider</a>
    <nav aria-label="Main Navigation">
      <ul class="nav-links">
        {
          links.map((link) => (
            <li>
              <a href={link.url}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .glass-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 16px 24px;
    display: flex;
    justify-content: center;
  }

  .header-inner {
    width: 100%;
    max-width: var(--max-width);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 24px;
    border-radius: var(--radius-pill);
    background: oklch(0.99 0.005 75 / 0.6);
    backdrop-filter: blur(17px) saturate(180%);
    -webkit-backdrop-filter: blur(17px) saturate(180%);
    border: 1px solid var(--border);
    box-shadow: 0 8px 62px 0 oklch(0.2 0.02 75 / 0.15);
  }

  .logo {
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .nav-links {
    display: flex;
    gap: 24px;
  }

  .nav-links a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--text);
  }
</style>
