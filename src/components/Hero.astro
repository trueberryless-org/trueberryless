---
import { Image } from "astro:assets";
import astro from "../assets/astro.png";
import npmx from "../assets/npmx.png";
import starlight from "../assets/starlight.png";

interface Props {
  name: string;
}

const { name } = Astro.props;
---

<section class="hero-viewport" id="hero-section">
  <div class="hexagon-space">
    <div
      class="hex"
      style="top: -5%; left: 65%; --size: 280px; z-index: 1; --speed: 0.4;"
    >
    </div>
    <div
      class="hex"
      style="top: 20%; left: 7%; --size: 400px; z-index: 2; --b-width: 3px; --speed: 0.5;"
    >
    </div>
    <div
      class="hex"
      style="top: 55%; left: 72%; --size: 220px; z-index: 30; --b-width: 3px; --b-style: dashed; --speed: 0.3;"
    >
    </div>
    <div
      class="hex"
      style="top: 65%; left: 4%; --size: 300px; z-index: 30; --b-style: dashed; --speed: 0.25;"
    >
    </div>
    <div
      class="hex"
      style="top: 50%; left: 33%; --size: 180px; z-index: 5; --speed: 0.35;"
    >
    </div>
    <div
      class="hex"
      style="top: 15%; left: 52%; --size: 120px; z-index: 6; --b-style: dashed; --b-width: 3px; --speed: 0.2;"
    >
    </div>
  </div>

  <div class="floating-logos">
    <div class="logo-parallax" style="top: 15%; left: 15%; --speed: 0.7;">
      <div class="logo-wrapper" style="animation-delay: 0s;">
        <Image src={astro} alt="Astro Logo" class="tech-logo" />
      </div>
    </div>
    <div class="logo-parallax" style="top: 75%; left: 57%; --speed: 0.05;">
      <div class="logo-wrapper" style="animation-delay: -1.5s;">
        <Image src={npmx} alt="npmx Logo" class="tech-logo" />
      </div>
    </div>
    <div class="logo-parallax" style="top: 30%; left: 77%; --speed: 0.45;">
      <div class="logo-wrapper" style="animation-delay: -3s;">
        <Image src={starlight} alt="Starlight Logo" class="tech-logo" />
      </div>
    </div>
  </div>

  <div class="hero-center-wrapper" id="hero-content">
    <!-- Blobs Removed -->
    <h1 class="hero-text">{name}</h1>
  </div>
</section>

<style is:global>
  /* Define CSS variable based on scroll */
  :root {
    --scroll-y: 0px;
  }
</style>

<style>
  .hero-viewport {
    position: relative;
    width: 100vw;
    max-width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
  }

  .hexagon-space {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .hex {
    --b-width: 2px;
    --b-color: var(--text-muted);
    --b-style: dotted;

    position: absolute;
    width: var(--size);
    height: calc(var(--size) * 1.1547);
    background-color: var(--bg-subtle);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    box-sizing: border-box;
    border-left: var(--b-width) var(--b-style) var(--b-color);
    border-right: var(--b-width) var(--b-style) var(--b-color);
    will-change: transform;
    /* CSS Parallax */
    transform: translate3d(0, calc(var(--scroll-y) * var(--speed, 0)), 0);
  }

  .hex::before,
  .hex::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: calc(var(--b-width) * -1);
    right: calc(var(--b-width) * -1);
    box-sizing: border-box;
    border-left: var(--b-width) var(--b-style) var(--b-color);
    border-right: var(--b-width) var(--b-style) var(--b-color);
  }

  .hex::before {
    transform: rotate(60deg);
  }

  .hex::after {
    transform: rotate(120deg);
  }

  .floating-logos {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 40;
  }

  .logo-parallax {
    position: absolute;
    will-change: transform;
    /* CSS Parallax */
    transform: translate3d(0, calc(var(--scroll-y) * var(--speed, 0)), 0);
  }

  .logo-wrapper {
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
    animation: floatLogo 6s ease-in-out infinite;
  }

  .tech-logo {
    width: 60%;
    height: 60%;
    object-fit: contain;
    transition:
      filter 0.3s ease,
      opacity 0.3s ease;
  }

  @keyframes floatLogo {
    0%,
    100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-16px) rotate(3deg);
    }
  }

  .hero-center-wrapper {
    position: relative;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    /* CSS Parallax */
    transform: translate3d(0, calc(var(--scroll-y) * 0.5), 0);
  }

  .hero-text {
    position: relative;
    z-index: 2;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      sans-serif;
    font-size: clamp(3.5rem, 8vw, 8rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1.1;
    color: var(--text);
    text-align: center;
    margin: 0;
    padding: 40px 60px;
  }

  .hero-text::before {
    content: "";
    position: absolute;
    inset: -100px;
    z-index: -1;
    backdrop-filter: blur(60px);
    -webkit-backdrop-filter: blur(60px);
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      black 40%,
      transparent 80%
    );
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    pointer-events: none;
  }
</style>

<script>
  let ticking = false;
  const root = document.documentElement;

  function updateScroll() {
    // Set CSS variable based on current scroll position
    root.style.setProperty("--scroll-y", `${window.scrollY}px`);
    ticking = false;
  }

  window.addEventListener(
    "scroll",
    () => {
      if (!ticking) {
        window.requestAnimationFrame(updateScroll);
        ticking = true;
      }
    },
    { passive: true }
  );

  // Initial set
  updateScroll();
</script>
