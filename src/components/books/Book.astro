---
import { Image } from "astro:assets";

interface Props {
  title: string;
  authors: string;
  coverUrl: string | null;
  rotation: string;
  hiveId: string;
  thickness: number;
}

const { title, authors, coverUrl, rotation, hiveId, thickness } = Astro.props;
---

<a
  href={`https://bookhive.buzz/books/${hiveId}`}
  class="book-item"
  style={`--rot: ${rotation}deg; --t: ${thickness}px;`}
  target="_blank"
  rel="noopener noreferrer"
>
  <div class="book-scene">
    <div class="book-3d">
      <div class="back-cover"></div>
      <div class="pages side"></div>
      <div class="pages bottom"></div>
      <div class="cover">
        {
          coverUrl ? (
            <Image src={coverUrl} alt={title} inferSize />
          ) : (
            <div class="fallback">{title}</div>
          )
        }
      </div>
    </div>
  </div>
  <div class="book-meta">
    <h3 class="title">{title}</h3>
    <p class="author">{authors}</p>
  </div>
</a>

<style>
  .book-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    color: inherit;
    outline: none;
  }

  .book-scene {
    perspective: 1000px;
    width: 140px;
    height: 210px;
  }

  .book-3d {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transform: rotateZ(var(--rot)) rotateY(-22deg) rotateX(12deg);
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .book-item:hover .book-3d {
    transform: translateY(-16px) translateX(8px)
      rotateZ(calc(var(--rot) + 6deg)) rotateY(-35deg) rotateX(15deg);
  }

  .cover,
  .back-cover {
    position: absolute;
    inset: 0;
    border-radius: 2px 4px 4px 2px;
  }

  .cover {
    transform: translateZ(calc(var(--t) / 2));
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--book-cover-bg);
    z-index: 2;
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .back-cover {
    transform: translateZ(calc(var(--t) / -2));
    background: var(--book-back);
    box-shadow: -4px 8px 15px rgba(0, 0, 0, 0.15);
    transition: box-shadow 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .book-item:hover .back-cover {
    box-shadow: -10px 20px 25px rgba(0, 0, 0, 0.2);
  }

  :global(.dark) .back-cover {
    box-shadow: -4px 8px 15px rgba(0, 0, 0, 0.5);
  }

  :global(.dark) .book-item:hover .back-cover {
    box-shadow: -10px 20px 25px rgba(0, 0, 0, 0.7);
  }

  .pages {
    position: absolute;
    background: var(--book-pages);
  }

  .pages.side {
    top: 1%;
    right: 2px;
    width: calc(var(--t) - 4px);
    height: 98%;
    transform-origin: right center;
    transform: translateZ(calc(var(--t) / 2 - 2px)) rotateY(-90deg);
    background: linear-gradient(
      to right,
      var(--book-pages-darker) 0%,
      var(--book-pages) 15%,
      var(--book-pages) 85%,
      var(--book-pages-darker) 100%
    );
  }

  .pages.bottom {
    left: 1%;
    bottom: 2px;
    height: calc(var(--t) - 4px);
    width: 98%;
    transform-origin: bottom center;
    transform: translateZ(calc(var(--t) / 2 - 2px)) rotateX(90deg);
    background: linear-gradient(
      to bottom,
      var(--book-pages-darker) 0%,
      var(--book-pages) 15%,
      var(--book-pages) 85%,
      var(--book-pages-darker) 100%
    );
  }

  .title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .author {
    font-size: 0.85rem;
    color: var(--text-muted);
    opacity: 0.7;
  }

  @media (prefers-reduced-motion: reduce) {
    .book-3d,
    .back-cover {
      transition: none;
    }

    .book-item:hover .book-3d {
      transform: rotateZ(var(--rot)) rotateY(-22deg) rotateX(12deg);
    }

    .book-item:hover .back-cover {
      box-shadow: -4px 8px 15px rgba(0, 0, 0, 0.15);
    }

    :global(.dark) .book-item:hover .back-cover {
      box-shadow: -4px 8px 15px rgba(0, 0, 0, 0.5);
    }
  }
</style>
