---
import HexBox from "../utils/HexBox.astro";

const { event } = Astro.props;
const { name, description, startsAt, endsAt, mode, status } = event.data;
---

<HexBox>
    <article class="event-card">
        <h3>{name}</h3>

        {
            (mode || status) && (
                <div class="meta">
                    {mode && <span class={`badge mode-${mode}`}>{mode}</span>}
                    {status && (
                        <span class={`badge status-${status}`}>{status}</span>
                    )}
                </div>
            )
        }

        {description && <p>{description}</p>}

        {
            (startsAt || endsAt) && (
                <div class="time-info">
                    {startsAt && (
                        <time datetime={startsAt.toISOString()}>
                            Start: {startsAt.toLocaleString()}
                        </time>
                    )}
                    {startsAt && endsAt && <br />}
                    {endsAt && (
                        <time datetime={endsAt.toISOString()}>
                            End: {endsAt.toLocaleString()}
                        </time>
                    )}
                </div>
            )
        }
    </article>
</HexBox>

<style>
    .event-card {
        width: 100%;
        max-width: 60ch;
        box-sizing: border-box;
        text-align: left;
        background-image: var(--grid-dot);
        background-size: var(--grid-size);
    }

    h3 {
        margin-bottom: 0.75rem;
        font-size: 1.1rem;
    }

    p {
        color: var(--text-main);
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }

    .meta {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .badge {
        font-size: 0.7rem;
        padding: 0.15rem 0.4rem;
        border-radius: 3px;
        font-weight: bold;
        border: 1px solid currentColor;
        background: transparent;
    }

    .badge.mode-online,
    .badge.status-active {
        color: var(--accent-cyan);
    }

    .badge.mode-hybrid,
    .badge.status-completed {
        color: var(--accent-green);
    }

    .badge.mode-in-person {
        color: var(--accent-magenta);
    }

    .badge:not([class*="mode-"]):not([class*="status-"]) {
        color: var(--text-muted);
    }

    .time-info {
        font-size: 0.75rem;
        color: var(--text-muted);
        font-family: inherit;
    }
</style>
