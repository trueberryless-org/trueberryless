---
import { getSkills, getEducation } from "@/lib/experience";
import Section from "@/components/utils/Section.astro";

const [sortedSkills, sortedEducation] = await Promise.all([
  getSkills(),
  getEducation(),
]);
---

{
  sortedSkills.length > 0 && (
    <Section title="Skills">
      <div class="badge-grid">
        {sortedSkills.map((skill) => (
          <span class="badge">{skill.name}</span>
        ))}
      </div>
    </Section>
  )
}

{
  sortedEducation.length > 0 && (
    <Section title="Education">
      <div class="badge-grid">
        {sortedEducation.map((edu) => (
          <span class="badge">
            {edu.institution}
            {edu.degree ? `, ${edu.degree}` : ""}
          </span>
        ))}
      </div>
    </Section>
  )
}

<style>
  .badge-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2em 0.6em;
    height: 1.6em;
    font-size: 0.95em;
    vertical-align: middle;

    background-color: var(--badge-bg);
    backdrop-filter: blur(8px);
    border-radius: 4px;

    color: var(--text);
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .badge:hover {
    background-color: var(--bg);
  }
</style>
