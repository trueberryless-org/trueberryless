---
import { getAugmentedPosts, processPost } from "@/lib/blog";
import Section from "@/components/utils/Section.astro";
import List from "@/components/utils/List.astro";
import ActionLink from "@/components/utils/ActionLink.astro";

const allPosts = await getAugmentedPosts();
const filteredPosts = allPosts
  .sort(
    (a: any, b: any) =>
      new Date(b.data.publishedAt).getTime() -
      new Date(a.data.publishedAt).getTime()
  )
  .slice(0, 3);
---

{
  filteredPosts.length > 0 && (
    <Section title="Recent Blog Posts">
      <ActionLink slot="header-actions" href="/blog" text="View all" />

      <List>
        {filteredPosts.map((post) => {
          const { title, postUrl } = processPost(post);
          return (
            <li class="list-item clickable">
              <a
                href={postUrl}
                target="_blank"
                rel="noopener noreferrer"
                style="display: contents; text-decoration: none; color: inherit;"
              >
                <div class="item-left">
                  <span class="item-main">{title}</span>
                </div>
                <span class="arrow">→</span>
              </a>
            </li>
          );
        })}
      </List>
    </Section>
  )
}
