---
import { getProcessedEvents } from "@/lib/events";
import Section from "@/components/utils/Section.astro";
import List from "@/components/utils/List.astro";

const allEvents = await getProcessedEvents();

const upcomingEvents = allEvents
  .filter((e) => !e.isPast)
  .sort((a, b) => a.startDate.getTime() - b.startDate.getTime())
  .slice(0, 3);
---

{
  upcomingEvents.length > 0 && (
    <Section title="Upcoming Events">
      <List>
        {upcomingEvents.map((event) => (
          <li class="list-item clickable">
            <a
              href={event.atmoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="event-link"
            >
              <div class="item-left">
                <span class="item-main">
                  {event.data.name || "Untitled Network Event"}
                </span>
              </div>
              <span class="arrow">→</span>
            </a>
          </li>
        ))}
      </List>
    </Section>
  )
}

<style>
  .event-link {
    display: flex;
    width: 100%;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }
</style>
