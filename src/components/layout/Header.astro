---
const pages = [
    { name: "blog", url: "/blog" },
    { name: "events", url: "/events" },
    { name: "projects", url: "/projects" },
];

const socials = [
    {
        name: "bluesky",
        url: "https://bsky.app/profile/trueberryless.org",
        label: "bluesky",
    },
    {
        name: "github",
        url: "https://github.com/trueberryless",
        label: "github",
    },
];
---

<header>
    <div>
        <a href="/">Felix Schneider</a>
    </div>
    <nav aria-label="Main Navigation">
        <ul class="links">
            <li>
                <ul class="text-links">
                    {
                        pages.map((page) => (
                            <li>
                                <a href={page.url}>{page.name}</a>
                            </li>
                        ))
                    }
                </ul>
            </li>
            <li aria-hidden="true" class="separator">•</li>
            <li>
                <ul class="icon-links">
                    {
                        socials.map((social) => (
                            <li>
                                <a href={social.url} aria-label={social.label}>
                                    {social.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </li>
        </ul>
    </nav>
</header>

<style>
    header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        width: 100%;
        display: flex;
        justify-content: space-between;
        padding: 2rem;
        font-size: 1.1rem;
        box-sizing: border-box;
        background-color: var(--bg-main);
    }

    nav {
        width: max-content;
    }

    nav .links {
        display: flex;
        gap: 1.5rem;
        align-items: center;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .text-links,
    .icon-links {
        display: flex;
        gap: 1.2rem;
        font-family: var(--font-mono);
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .separator {
        opacity: 0.5;
    }
</style>
