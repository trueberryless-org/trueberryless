---
import { getLiveCollection } from "astro:content";
import BaseHead from "@/layouts/BaseHead.astro";

const { entries: posts, error: postsError } = await getLiveCollection("posts");
const { entries: publications, error: publicationsError } =
  await getLiveCollection("publications");
const { entries: books, error: booksError } = await getLiveCollection("books");
const { entries: rsvps, error: rsvpsError } = await getLiveCollection("rsvps");
const { entries: blueskyPosts, error: blueskyPostsError } =
  await getLiveCollection("blueskyPosts");
const { entries: follows, error: followsError } =
  await getLiveCollection("follows");

if (postsError) console.error(postsError.message);
if (publicationsError) console.error(publicationsError.message);
if (booksError) console.error(booksError.message);
if (rsvpsError) console.error(rsvpsError.message);
if (blueskyPostsError) console.error(blueskyPostsError.message);
if (followsError) console.error(followsError.message);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <BaseHead
      title={"Debug Mode | Felix Schneider"}
      description={"View the website with raw data"}
    />
    <style>
      body {
        font-family: system-ui, sans-serif;
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
      }
      details {
        background: #f4f4f4;
        padding: 0.5rem;
        margin-bottom: 0.5rem;
        border-radius: 4px;
      }
      summary {
        cursor: pointer;
        font-weight: bold;
      }
      pre {
        white-space: pre-wrap;
        word-wrap: break-word;
        font-size: 0.85rem;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Live Overview (All Data Dump)</h1>

      <section>
        <h2>Posts</h2>
        {
          postsError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading posts:</strong> {postsError.message}
            </div>
          )
        }
        {
          posts?.map((item) => (
            <article>
              <details>
                <summary>{item.data.title || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Publications</h2>
        {
          publicationsError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading publications:</strong>{" "}
              {publicationsError.message}
            </div>
          )
        }
        {
          publications?.map((item) => (
            <article>
              <details>
                <summary>{item.data.name || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Books</h2>
        {
          booksError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading books:</strong> {booksError.message}
            </div>
          )
        }
        {
          books?.map((item) => (
            <article>
              <details>
                <summary>{item.data.title || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Events</h2>
        {
          rsvpsError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading events:</strong> {rsvpsError.message}
            </div>
          )
        }
        {
          rsvps?.map((item) => (
            <article>
              <details>
                <summary>{item.data.name || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Bluesky Posts</h2>
        {
          blueskyPostsError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading blueskyPosts:</strong>{" "}
              {blueskyPostsError.message}
            </div>
          )
        }
        {
          blueskyPosts?.map((item) => (
            <article>
              <details>
                <summary>
                  {item.data.text
                    ? item.data.text.substring(0, 60) + "..."
                    : item.id}
                </summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Follows</h2>
        {
          followsError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading follows:</strong> {followsError.message}
            </div>
          )
        }
        {
          follows?.map((item) => (
            <article>
              <details>
                <summary>{item.data.subject || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>
    </main>
  </body>
</html>
