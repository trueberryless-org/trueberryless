---
import { getLiveCollection } from "astro:content";
import BaseHead from "@/layouts/BaseHead.astro";

const { entries: posts, error: postsError } = await getLiveCollection("posts");
const { entries: books, error: booksError } = await getLiveCollection("books");
const { entries: events, error: eventsError } =
  await getLiveCollection("events");
const { entries: likes, error: likesError } = await getLiveCollection("likes");
const { entries: education, error: educationError } =
  await getLiveCollection("education");
const { entries: honor, error: honorError } = await getLiveCollection("honor");
const { entries: skill, error: skillError } = await getLiveCollection("skill");
const { entries: position, error: positionError } =
  await getLiveCollection("position");
const { entries: repos, error: reposError } = await getLiveCollection("repos");
const { entries: blueskyPosts, error: blueskyPostsError } =
  await getLiveCollection("blueskyPosts");
const { entries: follows, error: followsError } =
  await getLiveCollection("follows");

if (postsError) console.error(postsError.message);
if (booksError) console.error(booksError.message);
if (eventsError) console.error(eventsError.message);
if (likesError) console.error(likesError.message);
if (educationError) console.error(educationError.message);
if (honorError) console.error(honorError.message);
if (skillError) console.error(skillError.message);
if (positionError) console.error(positionError.message);
if (reposError) console.error(reposError.message);
if (blueskyPostsError) console.error(blueskyPostsError.message);
if (followsError) console.error(followsError.message);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <BaseHead
      title={"Debug Mode | Felix Schneider"}
      description={"View the website with raw data"}
    />
    <style>
      body {
        font-family: system-ui, sans-serif;
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
      }
      details {
        background: #f4f4f4;
        padding: 0.5rem;
        margin-bottom: 0.5rem;
        border-radius: 4px;
      }
      summary {
        cursor: pointer;
        font-weight: bold;
      }
      pre {
        white-space: pre-wrap;
        word-wrap: break-word;
        font-size: 0.85rem;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Live Overview (All Data Dump)</h1>

      <section>
        <h2>Posts</h2>
        {
          postsError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading posts:</strong> {postsError.message}
            </div>
          )
        }
        {
          posts?.map((item) => (
            <article>
              <details>
                <summary>{item.data.title || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Books</h2>
        {
          booksError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading books:</strong> {booksError.message}
            </div>
          )
        }
        {
          books?.map((item) => (
            <article>
              <details>
                <summary>{item.data.title || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Events</h2>
        {
          eventsError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading events:</strong> {eventsError.message}
            </div>
          )
        }
        {
          events?.map((item) => (
            <article>
              <details>
                <summary>{item.data.name || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Likes</h2>
        {
          likesError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading likes:</strong> {likesError.message}
            </div>
          )
        }
        {
          likes?.map((item) => (
            <article>
              <details>
                <summary>
                  {item.data.subjectRef?.replace(
                    "https://npmx.dev/package/",
                    ""
                  ) || item.id}
                </summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Education</h2>
        {
          educationError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading education:</strong> {educationError.message}
            </div>
          )
        }
        {
          education?.map((item) => (
            <article>
              <details>
                <summary>{item.data.institution || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Honors</h2>
        {
          honorError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading honors:</strong> {honorError.message}
            </div>
          )
        }
        {
          honor?.map((item) => (
            <article>
              <details>
                <summary>
                  {item.data.title || item.data.name || item.id}
                </summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Skills</h2>
        {
          skillError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading skills:</strong> {skillError.message}
            </div>
          )
        }
        {
          skill?.map((item) => (
            <article>
              <details>
                <summary>{item.data.name || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Positions</h2>
        {
          positionError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading positions:</strong> {positionError.message}
            </div>
          )
        }
        {
          position?.map((item) => (
            <article>
              <details>
                <summary>
                  {item.data.title || item.data.role || item.id}
                </summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Repositories</h2>
        {
          reposError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading repositories:</strong> {reposError.message}
            </div>
          )
        }
        {
          repos?.map((item) => (
            <article>
              <details>
                <summary>{item.data.name || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Bluesky Posts</h2>
        {
          blueskyPostsError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading blueskyPosts:</strong>{" "}
              {blueskyPostsError.message}
            </div>
          )
        }
        {
          blueskyPosts?.map((item) => (
            <article>
              <details>
                <summary>
                  {item.data.text
                    ? item.data.text.substring(0, 60) + "..."
                    : item.id}
                </summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>

      <section>
        <h2>Follows</h2>
        {
          followsError && (
            <div style="color: red; padding: 1rem; background: #fee;">
              <strong>Error loading follows:</strong> {followsError.message}
            </div>
          )
        }
        {
          follows?.map((item) => (
            <article>
              <details>
                <summary>{item.data.subject || item.id}</summary>
                <pre>{JSON.stringify(item.data, null, 2)}</pre>
              </details>
            </article>
          ))
        }
      </section>
    </main>
  </body>
</html>
