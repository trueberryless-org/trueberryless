---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/landing/Hero.astro";
import Intro from "@/components/landing/Intro.astro";
import RecentPosts from "@/components/landing/RecentPosts.astro";
import ReadingSummary from "@/components/landing/ReadingSummary.astro";
import UpcomingEvents from "@/components/landing/UpcomingEvents.astro";
import Experience from "@/components/landing/Experience.astro";

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=3600, must-revalidate"
);
---

<Layout title="Felix Schneider">
  <Hero name="Felix Schneider" />

  <main class="layout-stream">
    <Intro />
    <RecentPosts />
    <ReadingSummary />
    <UpcomingEvents />
    <Experience />
  </main>
</Layout>

<style>
  .layout-stream {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 80px 24px 80px 24px;
    background-color: var(--bg);
  }
</style>
